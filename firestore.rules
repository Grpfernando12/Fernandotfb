rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'clientName', 'vendorCode', 'trackingNumber', 'status', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.userId == request.auth.uid &&
             data.clientName is string && data.clientName.size() <= 200 && data.clientName.size() > 0 &&
             data.vendorCode is string && data.vendorCode.size() <= 100 &&
             data.trackingNumber is string && data.trackingNumber.size() <= 100 &&
             data.status is string && data.status in ['pendente', 'concluido'] &&
             data.createdAt is number;
    }

    function isValidQuickLink(data) {
      return data.keys().hasAll(['userId', 'name', 'url', 'clicks', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 150 && data.name.size() > 0 &&
             data.url is string && data.url.size() <= 2048 && data.url.size() > 0 &&
             data.clicks is number &&
             data.createdAt is number;
    }

    function isValidPostIt(data) {
      return data.keys().hasAll(['userId', 'text', 'color', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             data.color is string && data.color.size() <= 200 &&
             data.createdAt is number;
    }

    match /users/{userId} {
      // For creating a minimal user doc if needed
      allow get: if isSignedIn() && request.auth.uid == userId;

      match /tasks/{taskId} {
        allow get: if isSignedIn() && request.auth.uid == userId && isValidId(taskId);
        allow list: if isSignedIn() && request.auth.uid == userId && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(taskId) && isValidTask(incoming());
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(taskId) && isValidTask(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['clientName', 'vendorCode', 'trackingNumber', 'status'])
        );
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(taskId);
      }

      match /links/{linkId} {
        allow get: if isSignedIn() && request.auth.uid == userId && isValidId(linkId);
        allow list: if isSignedIn() && request.auth.uid == userId && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(linkId) && isValidQuickLink(incoming());
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(linkId) && isValidQuickLink(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['clicks'])
        );
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(linkId);
      }

      match /postIts/{postItId} {
        allow get: if isSignedIn() && request.auth.uid == userId && isValidId(postItId);
        allow list: if isSignedIn() && request.auth.uid == userId && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(postItId) && isValidPostIt(incoming());
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(postItId);
      }
    }
  }
}
